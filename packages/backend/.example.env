# Convex DEPLOYMENT environment variables.
# These are NOT loaded from a file — set them on the deployment with:
#   npx convex env set <NAME> <value>      (add CONVEX_AGENT_MODE=anonymous for a local deployment)
# This file documents what the backend reads.

# --- Guest auth (set automatically by `pnpm setup:mock-auth`) ---
# MOCK_JWT_PRIVATE_KEY   base64-encoded PKCS#8 RSA private key (signs guest tokens)
# MOCK_JWT_PUBLIC_JWK    public JWK (inlined into auth.config.ts JWKS)
# MOCK_JWT_KID           key id
# MOCK_JWT_ISSUER        guest token issuer (default https://guest.convex.local)

# --- AI chat (optional) ---
# Without this, /chat streams a mocked reply. With it, it streams via the Vercel AI Gateway.
AI_GATEWAY_API_KEY=
# Optional model override (default anthropic/claude-haiku-4.5)
# CHAT_MODEL=anthropic/claude-haiku-4.5

# --- WorkOS (optional — real auth) ---
# Set both to trust WorkOS access tokens. Leave empty (or set to "") for guest-only.
WORKOS_JWT_ISSUER=
WORKOS_JWKS_URL=
# Only if your AuthKit env emits an `aud` claim:
# WORKOS_JWT_AUDIENCE=
