{
  "expo": {
    "name": "chat",
    "slug": "chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "chat",
    "userInterfaceStyle": "automatic",
    "ios": {
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.example.chat"
    },
    "android": {
      "package": "com.example.chat",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "server"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to attach photos as inspection evidence.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to take photos as inspection evidence."
        }
      ],
      "expo-image",
      "expo-web-browser",
      "expo-system-ui",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
