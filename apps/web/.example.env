# Convex deployment URL (from `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=
# Optional: explicit HTTP-actions URL (local deployments serve them on a
# different port). Defaults to the `.convex.site` domain of NEXT_PUBLIC_CONVEX_URL.
NEXT_PUBLIC_CONVEX_SITE_URL=

# WorkOS AuthKit — https://dashboard.workos.com
# Leave these blank to use "Continue as guest" only (mock auth).
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# Must be at least 32 characters: `openssl rand -base64 24`
WORKOS_COOKIE_PASSWORD=
# Must match a redirect URI configured in the WorkOS dashboard
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
